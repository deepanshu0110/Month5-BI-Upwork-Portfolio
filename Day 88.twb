      <aliases enabled='yes' />
      <column caption='Category Avg Revenue' datatype='real' name='[Calculation_0279276447870976]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Category] : AVG([Revenue]) }' />
      </column>
      <column aggregation='Attribute' caption='Grand Category Revenue' datatype='real' name='[Calculation_0279276451123201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ EXCLUDE [Region] : SUM([Revenue]) }' />
      </column>
      <column caption='Avg Product Margin' datatype='real' name='[Calculation_0279276451938306]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Product_Name] : AVG([Profit_Margin_%]) }' />
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_0279276466298883]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Revenue])) &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Above Threshold' datatype='boolean' name='[Calculation_0279276467589124]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Profit_Margin_%] &gt;= [Parameters].[Parameter 2]' />
      </column>
      <column caption='Selected Metric' datatype='real' name='[Calculation_0279276469248005]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Revenue&quot; THEN SUM([Revenue])&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Units Sold&quot; THEN SUM([Units_Sold])&#13;&#10;ELSE AVG([Profit_Margin_%])&#13;&#10;END' />
      </column>
