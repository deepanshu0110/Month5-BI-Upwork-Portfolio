      <group caption='Electronics Products' name='[Product Name Set]' name-style='unqualified' user:ui-builder='filter-group'>
        <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
          <groupfilter function='member' level='[Product_Name]' member='&quot;Headphones&quot;' />
          <groupfilter function='member' level='[Product_Name]' member='&quot;Laptop&quot;' />
          <groupfilter function='member' level='[Product_Name]' member='&quot;Smartphone&quot;' />
          <groupfilter function='member' level='[Product_Name]' member='&quot;Smartwatch&quot;' />
          <groupfilter function='member' level='[Product_Name]' member='&quot;Speaker&quot;' />
